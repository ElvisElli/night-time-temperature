##Working directory and external sources====
setwd(dirname(getActiveDocumentContext()$path))
source("../plot_theme.R")
options(scipen = 6, digits = 4)
##Importing and organizing Leaf angle data====
##importing
locations <- read_excel("../../leaf_angle_data.xlsx",sheet = "SUMMARY",range = cell_cols("A:A"))
leaf_angle.df <- data.frame()
for (i in seq_along(locations$Experiment)) {
leaf.angle.base <- read_excel("../../leaf_angle_data.xlsx",
sheet = locations$Experiment[i]) %>%
mutate(CODE=locations$Experiment[i])
leaf_angle.df <- rbind(leaf_angle.df,leaf.angle.base)
}
##Organizing
rep.number <- read_excel("../../leaf_angle_data.xlsx",sheet = "fieldbook",range = cell_cols("N:R"))
YOR <- read_excel("../../leaf_angle_data.xlsx",sheet = "YOR")
##with PLOT_BID
rep.number2 <- read_excel("../../leaf_angle_data.xlsx",sheet = "fieldbook",range = cell_cols("N:S"))
leaf_angle.profile <- leaf_angle.df %>%
left_join(YOR) %>%
left_join(rep.number2) %>%
dplyr::select(-c(COL,RAN,zero_leaf)) %>% #only middle leaves for this paper
mutate(PED_YOR=paste0(YOR,"_",PED),
CODE_MAN=paste0(CODE,"_",MAN)) %>%
filter(!PED %in% c("3.3_110","3.4_110"),#inbred lines
!CODE %in% c("ILJE_CLEH"),#JER high def is very bad, will not consider
!CODE_MAN=="ILJE_CLEN_LowN") %>% #Low N is also bad
reshape2::melt(id.vars=c("PLANT","EOR","PED","MAN","CODE","YOR","REP","LOCATION","PED_YOR","CODE_MAN","PLOT_BID")) %>%
mutate(variable=ifelse(variable=="minus2_leaf","-2",
ifelse(variable=="minus4_leaf","-4",
ifelse(variable=="plus2_leaf","+2",
ifelse(variable=="plus4_leaf","+4","Flag")))),
REP=paste0("REP",REP),
PLANT=paste0("PL",PLANT),
value=as.numeric(value),
value=90-value,
DEN=ifelse(MAN=="20k","Historical",
ifelse(MAN=="25k","Historical",
ifelse(MAN=="30k","Historical","Current"))),
RM=ifelse(grepl("110",PED),"111-day","103-day")) %>%
relocate(PLOT_BID,CODE,LOCATION,RM,DEN,MAN,CODE_MAN,EOR,PED,YOR,PED_YOR,variable,REP,PLANT,value) %>%
mutate_at(c(1:9,11:13),as.factor) %>%
mutate(filtering=ifelse(CODE=="IAFS_FSCD" & PED=="6.5_110","no",
ifelse(CODE=="IAEM" & PED=="6.5_110","no","yes"))) %>% ##for high def locations hybrid 6.5_110, EOR 2010 has all the densities, so I'll remove it. It is only one hybrid from ERA 2010
filter(!is.na(value),
!is.na(YOR),
!filtering=="no") %>%
select(-filtering) %>%
as_tibble()
##flag
leaf_angle.flag <- read_excel("../jose_final/FLAG.xlsx",sheet = "final") %>%
left_join(YOR) %>%
left_join(rep.number2) %>%
select(-c(COL,RAN,Location,ANGLE)) %>%
mutate(PED_YOR=paste0(YOR,"_",PED),
CODE_MAN=paste0(CODE,"_",MAN)) %>%
filter(!PED %in% c("3.3_110","3.4_110")) %>% #inbred lines
rename(value=FLAG) %>%
mutate(REP=paste0("REP",REP),
DEN=ifelse(MAN=="20k","Historical",
ifelse(MAN=="25k","Historical",
ifelse(MAN=="30k","Historical","Current"))),
RM=ifelse(grepl("110",PED),"111-day","103-day"),
variable=as.factor("Flag leaf")) %>%
relocate(PLOT_BID,CODE,LOCATION,RM,DEN,MAN,CODE_MAN,EOR,PED,YOR,PED_YOR,variable,REP,PLANT,value) %>%
mutate_at(c(1:9,11:13),as.factor) %>%
mutate(variable="Flag",
PLANT=paste0("PL",PLANT),
filtering=ifelse(CODE=="IAFS_FSCD" & PED=="6.5_110","no",
ifelse(CODE=="IAEM" & PED=="6.5_110","no","yes")),) %>% ##for high def locations hybrid 6.5_110, EOR 2010 has all the densities, so I'll remove it. It is only one hybrid from ERA 2010
filter(!is.na(value),
!is.na(YOR),
!filtering=="no") %>%
select(-filtering) %>%
as_tibble()
leaf_angle.prof <- rbind(leaf_angle.profile,leaf_angle.flag) %>%
mutate(variable=factor(variable,levels = c("Flag","+4","+2","-2","-4")),
YOR=as.numeric(YOR))
##inspection
leaf_angle.prof %>%
filter(#CODE_MAN %in% c("ILJE_CLEN_HighN"),
variable %in% c("+2","-2")) %>%
ggplot(aes(x=YOR,y=value,colour=variable))+
geom_smooth(method = "lm",se=F) +
temp +
geom_point(alpha=0.5) +
scale_x_continuous(limits = c(1980,2040))+
labs(x="YOR",y="LA")+
theme(legend.text = element_text(size=12),
legend.position = "top")+
labs(y="Leaf angle (°)",x="Year of release")+
facet_wrap(~CODE_MAN)
#check ILJE
##Figure 3: genetic gain (Philip Dixon)====
##3A: BLUPS
##arranging and filtering the dataset
gxe.df <- leaf_angle.prof %>%
filter(DEN=="Current",
variable %in% c("-2","+2"),##only these leaves for genetic gain
!paste0(RM,variable)=="103-dayFlag") %>% ##103 had only 1985 and 2015 eras
group_by(CODE,LOCATION,RM,DEN,MAN,CODE_MAN,EOR,PED,YOR,PED_YOR,variable,REP) %>%
summarise(value=mean(value,na.rm=T))##avg across plants
##inspection plot
gxe.df %>%
ggplot(aes(x=YOR,y=value,colour=variable))+
geom_point()+
geom_smooth(method = "lm",se=F)+
facet_wrap(~CODE_MAN)+
temp
ggsave("plot per location.tiff",width=30,height=20,units ="cm",dpi=600,compression="lzw",bg="white")
#complete vs reduced model
gxe.complete <- gxe.df %>%
group_by(variable,RM) %>%
#mutate(YOR = YOR-mean(YOR)) %>% #this is to transform the data, mean YOR
nest() %>%
mutate(mix.model = map(data, ~try(lmer(value ~ YOR*CODE_MAN + (1|PED) + (1|REP:CODE_MAN) + (1|PED:CODE_MAN),
REML=T, data = .)))) %>%
gather(model,fit,mix.model)
#complete vs reduced model
gxe.reduced <- gxe.df %>%
group_by(variable,RM) %>%
#mutate(YOR = YOR-mean(YOR)) %>% #this is to transform the data, mean YOR
nest() %>%
mutate(mix.model = map(data, ~try(lmer(value ~ YOR + (1|PED) + (1|REP:CODE_MAN) + (1|PED:CODE_MAN) + (1|CODE_MAN),
REML=T, data = .)))) %>%
gather(model,fit,mix.model)
summary(gxe.reduced$fit[[1]])
plot(gxe.reduced$fit[[1]])
##deciding by comparing both models using anova function
anova(gxe.complete$fit[[1]],gxe.reduced$fit[[1]])
